__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Environment secrets
.env

# Mac system files
.DS_Store

# VS Code settings
.vscode/

# Jupyter notebooks checkpoints
.ipynb_checkpoints/

# Trained model
model/trained_model.pt

# Stray image files added by other tools
Images/
*.ico
*.jpg
*.jpeg
*.png

frontend/node_modules/
frontend/build/
